{
  "name": "swissarmypm",
  "version": "1.0.0",
  "description": "SwissArmyPM - Lightweight desktop project management tool",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
