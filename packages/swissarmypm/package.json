    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "immer": "^11.1.3",
    "lucide-react": "^0.468.0",
    "moment": "^2.30.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "vis-data": "^8.0.3",
    "vis-timeline": "^8.5.0",
    "zustand": "^5.0.2"
