{
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/shared/*": ["./src/shared/*"],
      "@/*": ["./src/renderer/*"]
    }
  },
  "include": ["src/renderer/**/*", "src/shared/**/*"],
  "exclude": [
    "src/renderer/features/archive/**/*",
    "src/renderer/pages/archive/**/*",
    "src/renderer/stores/useMyWorkStore.ts",
    "src/renderer/components/portfolio/**/*",
    "src/renderer/components/gantt/GanttChart.tsx",
    "src/renderer/components/gantt/GanttRow.tsx",
    "src/renderer/components/gantt/WorkItemExcelGantt.tsx"
  ]
}
