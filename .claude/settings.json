{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Bash(rm -rf *)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Read workflow/project-profile.yaml, workflow/active-task.yaml, and workflow/handoff.md before coding.'"
          }
        ]
      }
    ]
  }
}
